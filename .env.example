# ---- Weave / W&B (required) ----
WANDB_API_KEY=your-wandb-key
WANDB_PROJECT=glassbox
WEAVE_PROJECT=glassbox
WANDB_ENTITY=

# ---- Redis (live event bus + leaderboard) ----
REDIS_URL=redis://127.0.0.1:6379
REDIS_CLOUD_PASSWORD=

# ---- Swarm LLM (W&B Inference: OpenAI-compatible, traced by Weave) ----
OPENAI_API_KEY=your-wandb-key
OPENAI_BASE_URL=https://api.inference.wandb.ai/v1
GLASSBOX_LLM_MODEL=openai/gpt-oss-120b

# ---- Ports (3000/8000 reserved) ----
FRONTEND_PORT=3100
BACKEND_PORT=8100
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8100
# Fallback for the leaderboard panel's "open evals in Weave" link, used only when no
# graded version has a Weave URL yet (otherwise the project root is derived from a row).
# e.g. https://wandb.ai/<entity>/<project>/weave
NEXT_PUBLIC_WEAVE_URL=

# ---- Agent Mail (real agent-to-agent coordination + advisory file leases) ----
# Start the server with scripts/agent_mail.sh. Absent token => Redis mirror only.
AGENT_MAIL_URL=http://127.0.0.1:8765/api/
AGENT_MAIL_TOKEN=
AGENT_MAIL_PROJECT_KEY=
AGENT_MAIL_HOME=
