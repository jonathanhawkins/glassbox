{
  "version": 1,
  "ports": {
    "frontend": 3100,
    "backend": 8100
  },
  "redis": {
    "urlEnv": "REDIS_URL",
    "eventsStream": "glassbox:events",
    "plannerScores": "glassbox:planner_scores",
    "plannerMeta": "glassbox:planner_meta",
    "beadsState": "glassbox:beads",
    "skillState": "glassbox:skill",
    "runsList": "glassbox:runs",
    "runMetaPrefix": "glassbox:run:"
  },
  "eventTypes": [
    "run_started",
    "plan_started",
    "bead_created",
    "bead_claimed",
    "bead_done",
    "plan_gap_found",
    "bead_injected",
    "validation_passed",
    "validation_failed",
    "planner_rewrite",
    "run_finished",
    "agent_message",
    "agent_status",
    "log"
  ],
  "agentStatus": ["idle", "working", "done", "failed"],
  "agents": [
    "planner",
    "coordinator",
    "worker-1",
    "worker-2",
    "worker-3",
    "worker-4",
    "validator",
    "improver"
  ]
}
